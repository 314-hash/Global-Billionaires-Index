Ť# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git!

# ============================================
# CRITICAL: PRIVATE KEYS
# ============================================

# Your wallet private key (64 characters, NO 0x prefix)
# Get from MetaMask: Account Details â†’ Export Private Key
# âš ď¸Ź KEEP THIS SECRET - ANYONE WITH THIS CAN ACCESS YOUR FUNDS!
PRIVATE_KEY=your_private_key_here

# ============================================
# API KEYS
# ============================================

# BscScan API Key
# Get from: https://bscscan.com/myapikey
# Used for contract verification
BSC_API_KEY=your_bscscan_api_key_here

# ============================================
# OPTIONAL: ADDITIONAL SERVICES
# ============================================

# Alchemy/Infura (if using alternative RPC)
# ALCHEMY_API_KEY=your_alchemy_key_here
# INFURA_API_KEY=your_infura_key_here

# Etherscan (for multi-chain verification)
# ETHERSCAN_API_KEY=your_etherscan_key_here

# CoinMarketCap (for gas reporting)
# COINMARKETCAP_API_KEY=your_cmc_key_here

# ============================================
# NETWORK CONFIGURATION (OPTIONAL)
# ============================================

# Custom RPC endpoints (if needed)
# BSC_RPC_URL=https://bsc-dataseed.binance.org/
# BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# ============================================
# DEPLOYMENT SETTINGS (OPTIONAL)
# ============================================

# Gas price (in Gwei)
# GAS_PRICE=5

# Gas limit
# GAS_LIMIT=8000000

# ============================================
# NOTES
# ============================================

# How to use this file:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to Git (it's in .gitignore)
# 4. Only commit .env.example (this template)

# Security Best Practices:
# - Use different private keys for testnet and mainnet
# - Never share your private key with anyone
# - Consider using a hardware wallet for production
# - Rotate API keys regularly
# - Use environment-specific .env files for different deployments
